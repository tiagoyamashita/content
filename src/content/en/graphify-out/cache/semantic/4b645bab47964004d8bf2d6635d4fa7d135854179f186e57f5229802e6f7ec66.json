{"nodes": [{"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_sharding", "label": "Database sharding", "file_type": "concept", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Horizontal partitioning across independent DB instances for write and storage scale; exhaust replicas/cache/tuning first."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_replication", "label": "Replication", "file_type": "concept", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Copies same data to multiple nodes for read scale and HA; distinct from sharding's disjoint row sets."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_partitioning", "label": "Partitioning", "file_type": "concept", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Splits rows in one DB by range/list/hash to prune scans; still one primary unlike sharding."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_shard_router", "label": "Shard router", "file_type": "rationale", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Picks physical shard from shard key; styles include app-level hash, Vitess/Citus proxy, ORM, or managed services."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_shard_key", "label": "Shard key", "file_type": "rationale", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Most important design choice; needs high cardinality, access-aligned and write-aligned properties; co-locate entities queried together."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_consistent_hashing", "label": "Consistent hashing", "file_type": "rationale", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Maps keys and nodes on a ring so adding/removing a node moves only a slice of keys; used in DynamoDB, Cassandra, Redis Cluster."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_scatter_gather", "label": "Scatter-gather", "file_type": "rationale", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Queries without shard key hit all shards and merge; fix with GSI, lookup table, denormalize, or require tenant/user id in API."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_hot_shard", "label": "Hot shard", "file_type": "rationale", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Skew from celebrities, tenant whales, or time hotspots; mitigate with sub-shard split, cache, write queue, or separate KV store."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_hash_based", "label": "Hash-based sharding", "file_type": "rationale", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "shard_id = hash(key) % N for even spread; no cheap range queries; changing N remaps many keys unless consistent hashing."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_range_based", "label": "Range-based sharding", "file_type": "rationale", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Range scans hit one shard but risk hot shard if new keys cluster on latest range."}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_vitess", "label": "Vitess", "file_type": "concept", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_citus", "label": "Citus", "file_type": "concept", "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_sharding", "target": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_replication", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location": null, "weight": 1.0}, {"source": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_sharding", "target": "src_content_en_swe101_sysdesign_scalable_patterns_ix_database_sharding_partitioning", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "swe101/sysdesign/scalable-patterns/ix-database-sharding.md", "source_location